# Copy to secrets.toml (same folder) for local runs, and paste the same
# values into the app's "Secrets" panel on Streamlit Community Cloud.
# Without this [r2] section the app runs local-disk-only, same as before —
# R2 sync is a no-op.

[r2]
endpoint_url = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
access_key_id = "<R2_ACCESS_KEY_ID>"
secret_access_key = "<R2_SECRET_ACCESS_KEY>"
bucket = "<BUCKET_NAME>"
